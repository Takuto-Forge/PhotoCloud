{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "photocloud-thumbnail-worker",
  "main": "src/index.js",
  "compatibility_date": "2026-07-15",
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "r2_buckets": [
    {
      "binding": "PHOTOS",
      "bucket_name": "parfait-photocloud"
    },
    {
      "binding": "THUMBNAILS",
      "bucket_name": "photocloud-thumbnails"
    }
  ],
  "images": {
    "binding": "IMAGES"
  }
}
